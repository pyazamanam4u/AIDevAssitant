{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AzureOpenAI": {
    "Endpoint": "https://your-resource-name.openai.azure.com/",
    "ApiKey": "<YOUR_AZURE_OPENAI_API_KEY>",
    "ChatDeployment": "your-chat-deployment",
    "EmbeddingDeployment": "your-embedding-deployment"
  }

}
